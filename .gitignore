# --- Build Artifacts ---
node_modules/
dist/
dist-tauri/
binaries/

# --- Rust/Cargo ---
/src-tauri/target/
/src-tauri/Cargo.lock
# Keep Cargo.lock if this is an end-executable, but often 
# Tauri projects ignore it in the subfolder if the root has one.

# --- IDEs / Editors ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- OS Generated Files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Environment / Secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# --- Log Files ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Testing ---
/coverage
/.nyc_output

# --- TypeScript ---
*.tsbuildinfo